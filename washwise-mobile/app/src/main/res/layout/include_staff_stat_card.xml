<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_section_card"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/flStatIconContainer"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_service_icon_circle">

            <ImageView
                android:id="@+id/ivStatIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_box"
                app:tint="#2563EB" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvStatLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:gravity="end"
            android:letterSpacing="0.08"
            android:textColor="#9CA3AF"
            android:textSize="10sp"
            android:textStyle="bold"
            tools:text="TOTAL" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#111827"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="12" />

    <TextView
        android:id="@+id/tvStatCaption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#6B7280"
        android:textSize="11sp"
        tools:text="All orders" />
</LinearLayout>
